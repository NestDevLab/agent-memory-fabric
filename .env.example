AMF_RAW_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
AMF_RAW_ENCRYPTION_KEY_ID=local-v1
# AMF_RAW_KEY_RING_PATH=/run/secrets/agent-memory-fabric-key-ring.json
# Rotation form (preferred when more than one key exists):
# AMF_RAW_KEY_RING_JSON={"currentKeyId":"local-v2","keys":{"local-v1":"<base64-32-byte-key>","local-v2":"<base64-32-byte-key>"}}
AMF_DATA_PATH=var/agent-memory-fabric
AMF_CATALOG_KIND=sqlite
AMF_CATALOG_PATH=var/agent-memory-fabric/catalog.sqlite
# PostgreSQL catalog (production option; must use a dedicated isolated database):
# AMF_CATALOG_KIND=postgres
# AMF_CATALOG_DATABASE_URL=postgresql://agent_memory_fabric:<password>@db.example/agent_memory_fabric
# AMF_CATALOG_SSL_MODE=verify-full
# AMF_CATALOG_SSL_CA_PATH=/run/secrets/postgres-ca.pem
# AMF_CATALOG_POOL_MAX=10
# AMF_CATALOG_CONNECT_TIMEOUT_MS=5000
# AMF_CATALOG_QUERY_TIMEOUT_MS=15000
# AMF_CATALOG_STATEMENT_TIMEOUT_MS=10000
# Local development only. Production must mount and explicitly select a reviewed policy.
AMF_POLICY_PATH=./config/policies.example.json
AMF_MAX_BODY_BYTES=262144
AMF_MAX_QUERY_CHARS=4096
AMF_MAX_PROPOSAL_CHARS=32768
AMF_MAX_METADATA_BYTES=16384
AMF_MAX_IDEMPOTENCY_KEY_CHARS=200
AMF_AUDIT_TIMEOUT_MS=2000
AMF_CATALOG_HEALTH_TIMEOUT_MS=3000
AMF_MCP_SESSION_TTL_MS=900000
AMF_MCP_MAX_SESSIONS=1000
AMF_MCP_MAX_SESSIONS_PER_ACTOR=20
AMF_SERVER_ENABLED=false

# Disabled until the Mem0 v3 target collection and data migration are approved.
MEM0_BACKEND_KIND=disabled
MEM0_LLM_MODEL=qwen3.5:9b
MEM0_LLM_BASE_URL=http://localhost:11434
MEM0_EMBEDDER_MODEL=nomic-embed-text:latest
MEM0_EMBEDDER_BASE_URL=http://localhost:11434
MEM0_EMBEDDING_DIMS=768
MEM0_VECTOR_DB_HOST=localhost
MEM0_VECTOR_DB_PORT=5432
MEM0_VECTOR_DB_USER=change-me
MEM0_VECTOR_DB_PASSWORD=change-me
MEM0_VECTOR_DB_NAME=change-me
MEM0_VECTOR_STORE_COLLECTION=change-me
MEM0_VECTOR_STORE_HNSW=true
MEM0_VECTOR_STORE_DISKANN=false
MEM0_BACKEND_TIMEOUT_MS=20000
# Preferred first-class auth registry source. Use a mounted secret path in production.
AMF_AUTH_REGISTRY_PATH=./config/auth-registry.example.json
# Legacy alias; AMF_AUTH_REGISTRY_PATH takes precedence.
MEM0_AUTH_REGISTRY_PATH=./config/auth-registry.example.json
MEM0_AUTH_CACHE_TTL_MS=15000
# Optional backward-compatible n8n Data Table auth source. Used only when
# MEM0_AUTH_REGISTRY_PATH is unset.
# N8N_API_BASE_URL=http://localhost:5678
# N8N_AUTH_TABLE_ID=change-me
# N8N_API_KEY=change-me
PORT=8787
