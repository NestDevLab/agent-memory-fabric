{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://agent-memory-fabric.local/contracts/amf.capability-mcp-v1.schema.json", "title": "Capability MCP v1 conformance manifest", "type": "object", "additionalProperties": false,
  "required": ["schema", "advertisedTools", "authorizationMatrix", "scenarios"], "properties": { "schema": { "const": "amf.capability-mcp-conformance/v1" }, "advertisedTools": { "$ref": "#/$defs/tools" }, "authorizationMatrix": { "type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true, "items": { "$ref": "#/$defs/authRule" } }, "scenarios": { "type": "array", "minItems": 13, "maxItems": 13, "uniqueItems": true, "items": { "$ref": "#/$defs/scenario" } } },
  "$defs": {
    "tools": { "type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true, "items": { "enum": ["search", "read", "propose", "proposal_status", "status"] } }, "tool": { "enum": ["search", "read", "propose", "proposal_status", "status"] }, "scope": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{1,31}:[a-z0-9._-]{1,96}$" }, "scopes": { "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": { "$ref": "#/$defs/scope" } }, "purpose": { "enum": ["memory_recall", "conversation_recall", "memory_curation"] }, "resourceId": { "type": "string", "pattern": "^rid_[A-Za-z0-9_-]{8,128}$" }, "kinds": { "type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": { "enum": ["canonical_memory", "document", "conversation"] } },
    "searchArguments": { "type": "object", "additionalProperties": false, "required": ["query", "scopes", "purpose"], "properties": { "query": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "\\S" }, "kinds": { "$ref": "#/$defs/kinds" }, "scopes": { "$ref": "#/$defs/scopes" }, "purpose": { "$ref": "#/$defs/purpose" }, "limit": { "type": "integer", "minimum": 1, "maximum": 50 }, "cursor": { "type": ["string", "null"], "pattern": "^cur_[A-Za-z0-9_-]{16,256}$" } } },
    "readArguments": { "type": "object", "additionalProperties": false, "required": ["id", "scopes", "purpose"], "properties": { "id": { "$ref": "#/$defs/resourceId" }, "scopes": { "$ref": "#/$defs/scopes" }, "purpose": { "$ref": "#/$defs/purpose" } } }, "proposeArguments": { "type": "object", "additionalProperties": false, "required": ["scope", "claim", "purpose", "idempotencyKey"], "properties": { "scope": { "$ref": "#/$defs/scope" }, "claim": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "\\S" }, "purpose": { "const": "memory_curation" }, "idempotencyKey": { "type": "string", "pattern": "^req_[A-Za-z0-9_-]{8,128}$" } } }, "proposalStatusArguments": { "type": "object", "additionalProperties": false, "required": ["id", "scopes", "purpose"], "properties": { "id": { "$ref": "#/$defs/resourceId" }, "scopes": { "$ref": "#/$defs/scopes" }, "purpose": { "const": "memory_curation" } } }, "statusArguments": { "type": "object", "additionalProperties": false, "maxProperties": 0, "properties": {} },
    "searchRequest": { "type": "object", "additionalProperties": false, "required": ["name", "arguments"], "properties": { "name": { "const": "search" }, "arguments": { "$ref": "#/$defs/searchArguments" } } }, "readRequest": { "type": "object", "additionalProperties": false, "required": ["name", "arguments"], "properties": { "name": { "const": "read" }, "arguments": { "$ref": "#/$defs/readArguments" } } }, "proposeRequest": { "type": "object", "additionalProperties": false, "required": ["name", "arguments"], "properties": { "name": { "const": "propose" }, "arguments": { "$ref": "#/$defs/proposeArguments" } } }, "proposalStatusRequest": { "type": "object", "additionalProperties": false, "required": ["name", "arguments"], "properties": { "name": { "const": "proposal_status" }, "arguments": { "$ref": "#/$defs/proposalStatusArguments" } } }, "statusRequest": { "type": "object", "additionalProperties": false, "required": ["name", "arguments"], "properties": { "name": { "const": "status" }, "arguments": { "$ref": "#/$defs/statusArguments" } } },
    "request": { "oneOf": [{ "$ref": "#/$defs/searchRequest" }, { "$ref": "#/$defs/readRequest" }, { "$ref": "#/$defs/proposeRequest" }, { "$ref": "#/$defs/proposalStatusRequest" }, { "$ref": "#/$defs/statusRequest" }] },
    "readiness": { "type": "object", "additionalProperties": false, "required": ["name", "state"], "properties": { "name": { "$ref": "#/$defs/tool" }, "state": { "enum": ["ready", "unavailable"] } } },
    "resource": { "type": "object", "additionalProperties": false, "required": ["id", "kind", "text"], "properties": { "id": { "$ref": "#/$defs/resourceId" }, "kind": { "enum": ["canonical_memory", "document", "conversation"] }, "text": { "type": "string", "minLength": 1, "maxLength": 65536, "pattern": "\\S" } } },
    "proposal": { "type": "object", "additionalProperties": false, "required": ["id", "state"], "properties": { "id": { "$ref": "#/$defs/resourceId" }, "state": { "enum": ["queued", "pending", "review_required", "approved", "rejected", "applied", "failed"] } } },
    "publicResult": {
      "type": "object", "additionalProperties": false, "required": ["ok", "outcome"],
      "properties": { "ok": { "type": "boolean" }, "outcome": { "enum": ["found", "not_found", "queued", "pending", "ready", "unavailable", "forbidden", "invalid_request"] }, "id": { "$ref": "#/$defs/resourceId" }, "items": { "type": "array", "maxItems": 50, "items": { "$ref": "#/$defs/resource" } }, "resource": { "$ref": "#/$defs/resource" }, "proposal": { "$ref": "#/$defs/proposal" }, "nextCursor": { "type": ["string", "null"], "pattern": "^cur_[A-Za-z0-9_-]{16,256}$" }, "capabilities": { "type": "array", "minItems": 1, "maxItems": 5, "uniqueItems": true, "items": { "$ref": "#/$defs/readiness" } } },
      "allOf": [
        { "if": { "properties": { "outcome": { "const": "found" } }, "required": ["outcome"] }, "then": { "oneOf": [{ "required": ["items", "nextCursor"] }, { "required": ["resource"] }] } },
        { "if": { "properties": { "outcome": { "const": "queued" } }, "required": ["outcome"] }, "then": { "required": ["id"], "not": { "anyOf": [{ "required": ["items"] }, { "required": ["resource"] }, { "required": ["proposal"] }, { "required": ["capabilities"] }, { "required": ["nextCursor"] }] } } },
        { "if": { "properties": { "outcome": { "const": "pending" } }, "required": ["outcome"] }, "then": { "required": ["proposal"], "not": { "anyOf": [{ "required": ["items"] }, { "required": ["resource"] }, { "required": ["capabilities"] }, { "required": ["id"] }, { "required": ["nextCursor"] }] } } },
        { "if": { "properties": { "outcome": { "enum": ["ready", "unavailable"] } }, "required": ["outcome"] }, "then": { "required": ["capabilities"], "not": { "anyOf": [{ "required": ["items"] }, { "required": ["resource"] }, { "required": ["proposal"] }, { "required": ["id"] }, { "required": ["nextCursor"] }] } } },
        { "if": { "properties": { "outcome": { "enum": ["not_found", "forbidden", "invalid_request"] } }, "required": ["outcome"] }, "then": { "not": { "anyOf": [{ "required": ["items"] }, { "required": ["resource"] }, { "required": ["proposal"] }, { "required": ["id"] }, { "required": ["capabilities"] }, { "required": ["nextCursor"] }] } } },
        { "if": { "properties": { "outcome": { "enum": ["found", "queued", "pending", "ready"] } }, "required": ["outcome"] }, "then": { "properties": { "ok": { "const": true } } } },
        { "if": { "properties": { "outcome": { "enum": ["not_found", "unavailable", "forbidden", "invalid_request"] } }, "required": ["outcome"] }, "then": { "properties": { "ok": { "const": false } } } }
      ]
    },
    "authRule": { "type": "object", "additionalProperties": false, "required": ["tool", "capability", "permission", "purpose", "scopeBinding", "failure"], "properties": { "tool": { "$ref": "#/$defs/tool" }, "capability": { "$ref": "#/$defs/tool" }, "permission": { "enum": ["fabric:search", "fabric:read", "fabric:propose", "fabric:proposal_status", "fabric:status"] }, "purpose": { "type": "array", "minItems": 0, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/purpose" } }, "scopeBinding": { "enum": ["required", "none"] }, "failure": { "enum": ["not_found", "forbidden", "invalid_request"] } } },
    "registry": { "type": "object", "additionalProperties": false, "required": ["enabledCapabilities", "providerAssignments"], "properties": { "enabledCapabilities": { "type": "array", "minItems": 1, "maxItems": 5, "uniqueItems": true, "items": { "$ref": "#/$defs/tool" } }, "providerAssignments": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "type": "object", "additionalProperties": false, "required": ["capability", "providerId"], "properties": { "capability": { "$ref": "#/$defs/tool" }, "providerId": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{2,63}$" } } } } } },
    "scenario": { "type": "object", "additionalProperties": false, "required": ["id", "request", "expected"], "properties": { "id": { "enum": ["valid_defaults", "explicit_conversation", "denied_conversation_purpose", "denied_conversation_scope", "read_found", "read_no_existence_oracle", "proposal_queued", "proposal_lifecycle", "status_redaction", "missing_provider_startup", "ambiguous_provider_startup", "disabled_provider_assignment", "alias_non_advertisement"] }, "request": { "$ref": "#/$defs/request" }, "expected": { "$ref": "#/$defs/publicResult" }, "registry": { "$ref": "#/$defs/registry" }, "alias": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{2,63}$" } } }
  }
}
