{
  "baseUrl": "https://memory.example.invalid",
  "tokenFile": "/etc/agent-memory-fabric/conversation-memory-extractor.token",
  "readerGeneration": "conversation-v3",
  "stateFile": "/var/lib/agent-memory-fabric/conversation-memory-extractor/state.json",
  "legacyStateFile": "/var/lib/agent-memory-fabric/raw-memory-extractor/state.json",
  "codexWorkDir": "/var/lib/agent-memory-fabric/conversation-memory-extractor/codex",
  "model": "gpt-5.6-luna",
  "dailyInputTokens": 20000,
  "dailyOutputTokens": 4000,
  "maxInputTokensPerConversation": 2500,
  "maxOutputTokensPerConversation": 350,
  "maxClaimsPerConversation": 2,
  "transcriptItemLimit": 100,
  "planMinRemainingPercent": 25,
  "codexTimeoutMs": 90000,
  "codexRateLimitTimeoutMs": 15000,
  "qualityPolicyFile": "/etc/agent-memory-fabric/conversation-memory-quality-policy.json",
  "qualityKeyFile": "/etc/agent-memory-fabric/conversation-memory-quality.key.json",
  "qualityReportFile": "/var/lib/agent-memory-fabric/conversation-memory-extractor/quality-report.json",
  "qualityReleaseDigest": "sha256:replace-with-the-release-digest",
  "qualityGateMaxAgeMs": 86400000,
  "qualitySampleMaxConversations": 12
}
