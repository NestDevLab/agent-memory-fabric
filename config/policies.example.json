{
  "actors": {
    "main-openclaw": {
      "mode": "allow_all"
    },
    "openclaw-tirrenia": {
      "mode": "scoped",
      "allowedScopes": ["tirrenia"]
    }
  },
  "scopes": {
    "main-lab": {
      "backendUserId": "openmemory"
    },
    "domain:main-lab": {
      "backendUserId": "openmemory"
    },
    "room:team": {
      "backendUserId": "openmemory"
    },
    "person:alice": {
      "backendUserId": "openmemory"
    },
    "relationship:team": {
      "backendUserId": "openmemory"
    },
    "tirrenia": {
      "backendUserId": "openclaw_tirrenia"
    },
    "domain:tirrenia": {
      "backendUserId": "openclaw_tirrenia"
    }
  }
}
