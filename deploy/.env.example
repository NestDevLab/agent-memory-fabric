# Legacy v2 local/shadow reference values. Copy to deploy/.env for this
# example only; Compose performs all substitution. No additional environment
# file or runtime override is supported. This is not a production configuration.

# The published example endpoint is always loopback. Choose only the local port.
AMF_HOST_PORT=8787

# Required local example values.
AMF_DB_PASSWORD=change-me-local-only
AMF_POLICY_REVISION=example-policy-v2
AMF_SERVICE_UID=1000
AMF_SERVICE_GID=1000
PAM_APPLICATOR_TOKEN=change-me-local-only

# Keep embeddings pinned for comparable local/shadow results.
NOMIC_EMBED_TEXT_DIGEST=sha256:0a109f422b47e3a30ba2b10eca18548e944e8a23073ee3f3e947efcf3c45e59f

# Synthetic relative inputs for a disposable example. Replace them only with
# local test fixtures; do not point this reference at an existing data store.
AMF_POLICY_FILE=./example-input/policy.json
AMF_AUTH_REGISTRY_FILE=./example-input/auth-registry.json
AMF_KEY_RING_FILE=./example-input/raw-key-ring.json
AMF_INGEST_KEY_RING_FILE=./example-input/ingest-key-ring.json
AMF_CONTEXT_KEY_RING_FILE=./example-input/context-key-ring.json
PAM_RUNTIME_DIR=./example-input/pam-runtime
PAM_SOURCE_DIR=./example-input/portable-agent-memory
BRAIN_SHARED_DIR=./example-input/brain-shared
