# Copy to deploy/.env and fill in. deploy/.env is gitignored (root .gitignore: .env*).

# Address amf-server binds to. 127.0.0.1 for a local smoke test; the host LAN
# IP (e.g. 192.168.1.115) on the server. AMF_HOST_PORT changes the published
# host port when 8787 is already taken locally.
AMF_BIND_ADDRESS=127.0.0.1
AMF_HOST_PORT=8787

# Postgres password. Single place; the catalog URL is constructed in
# docker-compose.yml from this value.
AMF_DB_PASSWORD=change-me-local-only

# Must name the revision your mounted policy file represents. The edge client
# sends the same value as OBSIDIAN_AMF_POLICY_REVISION.
AMF_POLICY_REVISION=policy-local-v1

# Container uid:gid. Must match the owner of the bind-mounted host dirs —
# AMF validates mount ownership against the process euid. macOS (Docker
# Desktop/Rancher Desktop): host dirs appear as 503:20. Linux: 1000:1000.
# If you change this after first boot, chown the amf-data volume to match.
AMF_SERVICE_UID=1000
AMF_SERVICE_GID=1000

# Embedding model digest. The fabric container AND every edge host hook must
# run nomic-embed-text at this exact digest (decision 5: one shared 768-dim
# vector space). ollama's API rejects digest-qualified model names, so
# enforcement is: always pull by this digest + periodically compare digests
# (see README "Verify the shared embedding digest"). Pinned 2026-07-18.
NOMIC_EMBED_TEXT_DIGEST=sha256:0a109f422b47e3a30ba2b10eca18548e944e8a23073ee3f3e947efcf3c45e59f

# AMF↔PAM applicator token. The PAM child reads it from AMF's environment;
# its sha256 goes into secrets.local/pam-runtime/pam-workspace-config.json.
PAM_APPLICATOR_TOKEN=change-me-local-only

# Host paths to secret/config files, mounted read-only. Formats:
# ../config/*.example.json and ../docs/*-provisioning.md. See deploy/README.md
# for generating a throwaway local dev set under ./secrets.local/.
AMF_POLICY_FILE=./secrets.local/policy.json
AMF_AUTH_REGISTRY_FILE=./secrets.local/auth-registry.json
AMF_KEY_RING_FILE=./secrets.local/raw-key-ring.json
AMF_INGEST_KEY_RING_FILE=./secrets.local/ingest-key-ring.json
AMF_CONTEXT_KEY_RING_FILE=./secrets.local/context-key-ring.json

# Service-owned PAM runtime dir (routing key ring, PAM workspace config,
# applicator state key). Must be owned 1000:1000 with mode 0700.
PAM_RUNTIME_DIR=./secrets.local/pam-runtime

# Reviewed portable-agent-memory source checkout, mounted read-only.
PAM_SOURCE_DIR=../../portable-agent-memory

# Canonical PAM workspace (records). State, not secret; ../var is gitignored.
# Must be writable by uid 1000.
BRAIN_SHARED_DIR=../var/brain-shared
