{
  "name": "agent-memory-fabric",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "description": "Shared REST/MCP memory fabric with encrypted RAW storage and scoped proposal curation",
  "bin": {
    "amf": "scripts/amf-integrations.mjs"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "node --watch src/server.mjs",
    "check": "node src/server.mjs --check",
    "operator:provision-raw-collector": "node scripts/amf-provision-raw-collector.mjs",
    "operator:provision-recall-consumer": "node scripts/amf-provision-recall-consumer.mjs",
    "operator:provision-interactive-recall": "node scripts/amf-provision-interactive-recall.mjs",
    "operator:provision-document-client": "node scripts/amf-provision-document-client.mjs",
    "operator:provision-session-routes": "node scripts/amf-provision-session-routes.mjs",
    "operator:preflight-pam-runtime": "node src/operator/pam-runtime-private-dir.mjs",
    "operator:migration-pause": "node scripts/amf-migration-pause.mjs",
    "integrations": "node scripts/amf-integrations.mjs",
    "mcp:interactive-recall": "node scripts/amf-interactive-recall-mcp.mjs",
    "test:conversation-event-outbox": "node --test scripts/test-conversation-event-v3-outbox.mjs",
    "test:conversation-event-ingest": "node --test scripts/test-conversation-event-v3-ingest-endpoint.mjs",
    "test:conversation-archive": "node --test scripts/test-conversation-archive-v1-adapters.mjs",
    "test:m4-reconciliation": "node --test scripts/test-m4-reconciliation-reader.mjs",
    "test:m4-backfill-coordinator": "node --test scripts/test-m4-backfill-coordinator.mjs",
    "test:content-protection": "node --test scripts/test-content-protection-v1-contract.mjs scripts/test-content-protection-v1-runtime.mjs scripts/test-content-protection-v1-measurements.mjs",
    "measure:content-protection": "node scripts/measure-content-protection-v1.mjs",
    "test:conversation-session-view": "node --test scripts/test-conversation-session-view-v2.mjs",
    "test": "node --test scripts/test-*.mjs",
    "test:auth": "node --test scripts/test-auth-registry.mjs"
  },
  "dependencies": {
    "@langchain/core": "1.1.47",
    "@supabase/supabase-js": "2.103.2",
    "better-sqlite3": "12.9.0",
    "gcp-metadata": "7.0.1",
    "mem0ai": "3.0.13",
    "natural": "8.1.1",
    "ollama": "0.5.18",
    "pg": "8.11.3"
  }
}
